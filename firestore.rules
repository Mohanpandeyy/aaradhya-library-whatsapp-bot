rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if ID is valid
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Students collection
    match /students/{studentId} {
      allow read, write: if true; // Open for this tool's simplicity, but should be hardened with Auth
    }

    // Templates collection
    match /templates/{templateId} {
      allow read, write: if true; // Open for this tool's simplicity
    }
  }
}

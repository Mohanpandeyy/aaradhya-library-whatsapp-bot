{
  "entities": {
    "student": {
      "title": "Student",
      "description": "Student record in the library system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "feeAmount": { "type": "number" },
        "dueDateDay": { "type": "number" },
        "status": { "type": "string", "enum": ["Paid", "Pending"] },
        "admitStatus": { "type": "string" },
        "seatNumber": { "type": "string" },
        "nextDueDate": { "type": "string" },
        "muteReminders": { "type": "boolean" },
        "lastPaidDate": { "type": "string" },
        "lastReminderSent": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "phone", "feeAmount", "dueDateDay", "status"]
    },
    "template": {
      "title": "Message Template",
      "description": "WhatsApp message template",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["message"]
    },
    "payment": {
      "title": "Payment Record",
      "description": "Payment history record",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "amount": { "type": "number" },
        "months": { "type": "number" },
        "paidAt": { "type": "string", "format": "date-time" },
        "paidDate": { "type": "string" }
      },
      "required": ["studentId", "studentName", "amount", "paidAt"]
    },
    "setting": {
      "title": "Application Setting",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "libraryName": { "type": "string" },
        "upiId": { "type": "string" },
        "defaultFee": { "type": "number" },
        "totalSeats": { "type": "number" },
        "reminderTime": { "type": "string" }
      },
      "required": ["libraryName", "upiId", "defaultFee"]
    }
  },
  "firestore": {
    "students": {
      "schema": "student",
      "description": "Collection of students"
    },
    "templates": {
      "schema": "template",
      "description": "Collection of message templates"
    },
    "payments": {
      "schema": "payment",
      "description": "Collection of payment history"
    },
    "settings": {
      "schema": "setting",
      "description": "Collection of application settings"
    }
  }
}
